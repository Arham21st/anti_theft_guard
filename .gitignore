*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Vercel (local project link metadata)
.vercel/

# ==========================================
# Android Specifics
# ==========================================
/android/app/debug
/android/app/profile
/android/app/release

# Android Studio / Gradle local configurations
.gradle/
local.properties
*.keystore
*.jks
/android/.gradle/
/android/captures/
/android/local.properties

# ==========================================
# iOS Specifics
# ==========================================
# CocoaPods - Pods/ should be ignored; Podfile.lock should be tracked
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh

# Xcode user settings and workspace state
**/ios/**/project.xcworkspace/xcuserdata/
**/ios/**/xcuserdata/
**/ios/**/DerivedData/

# ==========================================
# Web Specifics
# ==========================================
# Flutter web build outputs are handled by /build/, but local server caches live here
.web_plugins/

# ==========================================
# Environment / Secret Configurations
# ==========================================
.env
.env.*

.agents/
.claude/
.vercel
.env*
