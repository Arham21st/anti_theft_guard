# Files excluded from Vercel uploads. Vercel rebuilds the web app from source
# on its own build box, so none of these local artifacts or native platforms
# are needed.

# Local build artifacts
build/
.dart_tool/

# Native platform source (the web deploy doesn't compile them)
android/
ios/
windows/
linux/
macos/

# Version control + caches
.git/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# Local env / tooling
.env.local
.vscode/
.idea/
.agents/
.claude/

# Existing local web output is regenerated by the Vercel build
build/web/
