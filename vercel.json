{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash build-vercel.sh",
  "outputDirectory": "build/web",
  "framework": null,
  "installCommand": "echo 'no install step'",
  "rewrites": [
    {
      "source": "/((?!assets/|icons/|favicon|manifest.json|flutter.js|flutter_bootstrap.js|index.html|main.dart.js|version.json|canvaskit/).*)",
      "destination": "/index.html"
    }
  ]
}
